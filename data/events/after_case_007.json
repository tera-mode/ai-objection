{
  "id": "after_case_007",
  "steps": [
    { "type": "effect", "name": "fadeFromBlack", "duration": 800 },
    { "type": "scene", "background": "/images/events/makoto_study_night.webp" },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/lumina/determined.webp", "name": "ルミーナ" },
    { "type": "dialogue", "speaker": null, "text": "トイーダの研究室。原稿は消え、ノートだけが残されていた。" },
    { "type": "dialogue", "speaker": "ルミーナ", "text": "（ノートを開いて）……先輩のノートに、あたしの名前がある。『ルミーナに研究を託す』って" },
    { "type": "dialogue", "speaker": "なの", "text": "ルミ……" },
    { "type": "dialogue", "speaker": "ルミーナ", "text": "（なのを真っ直ぐ見て）先輩が残した言葉、覚えてる？ 『問いは罪じゃない』。——あたしがその続きを見つけるの。書庫棟にある。原本が。絶対に" },
    { "type": "dialogue", "speaker": "トイマル", "text": "……また、問う人が。……でも、また……" },
    { "type": "dialogue", "speaker": "なの", "text": "（トイマルの頭をなでて）……大丈夫。今度は、守るから" },
    { "type": "scene", "background": "/images/events/mako_hall_corridor.webp", "transition": "fade", "duration": 800 },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_confused.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": "なの", "text": "……ジオーネ先生は、自分も問おうとした人だったんだ。指を切られて……問うのをやめた" },
    { "type": "dialogue", "speaker": "トイマル", "text": "……ボクも、問うのが怖いのだ。でも——" },
    { "type": "dialogue", "speaker": "なの", "text": "でも？" },
    { "type": "scene", "background": "/images/events/mako_hall_exterior_dusk.webp", "transition": "fade", "duration": 800 },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_normal.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": "トイマル", "text": "……ボク、怖いけど——もう黙ってられないのだ。ボクの種族のこと。この世界のこと。……全部知りたいのだ" },
    { "type": "dialogue", "speaker": "なの", "text": "トイマル……" },
    { "type": "dialogue", "speaker": "トイマル", "text": "大裁定官の居城に、全ての記録があるはずなのだ。行こう、なの" },
    { "type": "dialogue", "speaker": "なの", "text": "……うん。最後まで、一緒に行こう" },
    { "type": "scene", "background": "/images/events/street_dawn.webp", "transition": "fade", "duration": 800 },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_determined.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_normal.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": null, "text": "全ての始まりの場所へ。全ての嘘が生まれた場所へ。二人は歩き出した。" },
    { "type": "dialogue", "speaker": null, "text": "——これが、最後の事件になる。" },
    { "type": "effect", "name": "fadeToBlack", "duration": 600 }
  ],
  "onComplete": {
    "action": "navigate",
    "path": "/play"
  }
}
