{
  "id": "after_case_008",
  "steps": [
    { "type": "effect", "name": "fadeFromBlack", "duration": 800 },
    { "type": "scene", "background": "/images/events/makoto_old_archive.webp" },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_confused.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": null, "text": "全てが終わった。フルモーンの告白。50年間守られた原本。そして——マコトの誓いの真実。" },
    { "type": "dialogue", "speaker": "トイマル", "text": "……なの" },
    { "type": "dialogue", "speaker": "なの", "text": "ん？" },
    { "type": "dialogue", "speaker": "トイマル", "text": "ボクの種族は、問う者の傍にいる者だったのだ。ボクは……嘘がわからないんじゃなくて……『わかっちゃいけない』って教えられたのだ" },
    { "type": "dialogue", "speaker": "トイマル", "text": "……ボクの種族は、ずっと黙ってたのだ。ただ記録して、従うだけで——それが正しいと思ってたのだ。でも……それ、ちがったのだ" },
    { "type": "dialogue", "speaker": null, "text": "トイマルの目に、今まで見たことのない光が灯った。大きな耳がピンと立つ。小さな体が、少しだけ大きく見えた。" },
    { "type": "scene", "background": "/images/events/street_dawn.webp", "transition": "fade", "duration": 800 },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_normal.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": "なの", "text": "……トイマル。この世界は、変われるかな" },
    { "type": "dialogue", "speaker": "トイマル", "text": "変わるのだ。ボクが——ボクたちが問い続ければ。なのが教えてくれたのだ。問うことは、壊すことじゃないのだ。本当のものを見つけることなのだ" },
    { "type": "dialogue", "speaker": "なの", "text": "……うん。そうだね" },
    { "type": "dialogue", "speaker": null, "text": "朝の光が石畳を照らす。コトハの街はいつもと変わらない。でも——たった一つの言葉が、少しずつ何かを変え始めていた。" },
    { "type": "effect", "name": "fadeToBlack", "duration": 600 }
  ],
  "onComplete": {
    "action": "navigate",
    "path": "/event/ending"
  }
}
