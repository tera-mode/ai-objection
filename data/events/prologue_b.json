{
  "id": "prologue_b",
  "steps": [
    { "type": "effect", "name": "fadeFromBlack", "duration": 800 },
    { "type": "scene", "background": "/images/backgrounds/fantasy_bg.jpg" },
    { "type": "character", "position": "left", "image": "/images/characters/gamekichi/defeated.png" },
    { "type": "dialogue", "speaker": "ガメ吉", "text": "……ちくしょう……ガキに見破られるなんて……" },
    { "type": "character", "position": "left", "image": null },
    { "type": "dialogue", "speaker": null, "text": "衛兵がガメ吉を取り押さえる。老婆がリンゴを取り戻して泣いている。" },
    { "type": "dialogue", "speaker": null, "text": "周りの住人たちがこちらを見ている。感謝ではなく——驚きと、戸惑いの目。まるで信じられないものを見たような顔。" },
    { "type": "dialogue", "speaker": null, "text": "——足元から、小さな声。" },
    { "type": "character", "position": "left", "image": "/images/characters/toimaru/event_normal.png" },
    { "type": "dialogue", "speaker": "トイマル", "text": "……すごいのだ" },
    { "type": "dialogue", "speaker": null, "text": "荷車の影から、小さな生き物がこちらを見ていた。大きな耳。緑色の毛並み。オーバーサイズのコート。" },
    { "type": "dialogue", "speaker": "トイマル", "text": "『なんで？』って聞いただけで、嘘が壊れたのだ……。こんなの、見たことないのだ" },
    { "type": "character", "position": "right", "image": "/images/characters/nano/event_normal.png" },
    { "type": "dialogue", "speaker": "なの", "text": "……あんた、なに？" },
    { "type": "dialogue", "speaker": "トイマル", "text": "ボクはトイマルなのだ！ キミ、すごいのだ！ ボクと来るのだ！" },
    { "type": "dialogue", "speaker": "なの", "text": "いやいや待って、まずここがどこか教えてよ！" },
    { "type": "effect", "name": "fadeToBlack", "duration": 600 },
    { "type": "dialogue", "speaker": null, "text": "小さな生き物に手を引かれて、知らない街を歩き出す。——これが全ての始まりだった。" },
    { "type": "effect", "name": "fadeToBlack", "duration": 600 }
  ],
  "onComplete": {
    "action": "navigate",
    "path": "/play"
  }
}
