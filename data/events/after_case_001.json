{
  "id": "after_case_001",
  "steps": [
    { "type": "effect", "name": "fadeFromBlack", "duration": 800 },
    { "type": "scene", "background": "/images/events/market_evening.webp" },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_happy.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": "トイマル", "text": "なの、すごかったのだ！ モリエルの嘘、全部見破ったのだ！" },
    { "type": "dialogue", "speaker": "なの", "text": "……ねぇトイマル。あの人、最後に言ってたよね。『みんなが信じれば本物になる』って" },
    { "type": "dialogue", "speaker": "トイマル", "text": "うん。……でもそれ、嘘なのだ？ なのが証明したのだ" },
    { "type": "scene", "background": "/images/events/street_evening.webp", "transition": "fade", "duration": 800 },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_confused.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": null, "text": "帰り道。通りの端で、なのの目が古い看板に止まった。" },
    { "type": "dialogue", "speaker": "なの", "text": "……この看板、何か塗りつぶされてる。うっすら……『真を問え』？" },
    { "type": "dialogue", "speaker": "トイマル", "text": "……？ ボク、その言葉、知らないのだ" },
    { "type": "dialogue", "speaker": "なの", "text": "（……『問うな、信じよ』の世界に、『真を問え』って書いてあった。誰が書いたんだろう）" },
    { "type": "scene", "background": "/images/events/kotha_street_evening.webp", "transition": "fade", "duration": 800 },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "dialogue", "speaker": null, "text": "事件を解いた直後。衛兵がなのに近づいてきた。" },
    { "type": "dialogue", "speaker": "衛兵", "text": "お前、また『なんで』とか聞いてたな。マコトの誓いを知らんのか" },
    { "type": "dialogue", "speaker": null, "text": "背筋のピンと伸びた白髪の老女が、割って入った。" },
    { "type": "character", "position": "right", "image": "/images/characters/hakaal/neutral.webp", "name": "ハカール" },
    { "type": "dialogue", "speaker": "ハカール", "text": "衛兵どの。この子は私の用で来てもらったのです" },
    { "type": "dialogue", "speaker": "ハカール", "text": "……面白い子だね。あの商人の嘘、街中が信じてたのに。君だけが『おかしい』って言った" },
    { "type": "dialogue", "speaker": "なの", "text": "あの……助けてくれてありがとうございます" },
    { "type": "dialogue", "speaker": "ハカール", "text": "私も『おかしいものはおかしい』と言い続けて25年。……闘技場で気になることがあってね。もしよかったら、今度話を聞いてくれないかい？" },
    { "type": "dialogue", "speaker": "なの", "text": "（頷いて）……はい！" },
    { "type": "scene", "background": "/images/events/street_evening.webp", "transition": "fade", "duration": 600 },
    { "type": "character", "position": "left", "image": "/images/characters/nano/event_normal.png", "name": "なの" },
    { "type": "character", "position": "right", "image": "/images/characters/toimaru/event_normal.png", "name": "トイマル" },
    { "type": "dialogue", "speaker": "トイマル", "text": "なの！ 大変なのだ！ 闘技場で……人が死んだらしいのだ！" },
    { "type": "dialogue", "speaker": "なの", "text": "闘技場……？" },
    { "type": "dialogue", "speaker": "トイマル", "text": "すごく強い戦士が関わってるらしいのだ。……なの、怖いのだ……" },
    { "type": "effect", "name": "fadeToBlack", "duration": 600 }
  ],
  "onComplete": {
    "action": "navigate",
    "path": "/play"
  }
}
